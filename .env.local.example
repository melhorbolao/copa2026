# Supabase — copie este arquivo para .env.local e preencha com suas credenciais
# Encontre em: https://app.supabase.com → seu projeto → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Apenas no servidor (nunca expor no cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# E-mail (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@melhorbolao.app.br
ADMIN_EMAIL=gmousinho@gmail.com
AUDIT_EMAIL=auditoria@melhorbolao.app.br

# URL pública do site
NEXT_PUBLIC_BASE_URL=https://melhorbolao.app.br

# Segredo dos cron jobs (gere com: openssl rand -hex 32)
# Vercel injeta automaticamente em produção; configure também em Settings > Environment Variables
CRON_SECRET=seu_segredo_aleatorio_aqui
